# ---- Required ----
API_ID=123456                 # from my.telegram.org
API_HASH=your_api_hash
BOT_TOKEN=123456:ABC-main-bot-token
BASE_URL=https://your-app.koyeb.app   # public URL (https). scheme auto-added if missing
HASH_SECRET=long-random-string        # signs stream links

# ---- Optional: storage / streaming ----
LOG_CHANNEL=0                 # private channel id (-100...) for permanent storage + worker streaming; 0 = no-channel mode
DATABASE_URL=                 # MongoDB Atlas URL; empty = in-memory (resets on restart)
SESSION_STRING=               # optional Pyrogram session string to avoid re-login
MULTI_TOKEN1=                 # extra worker bot tokens (also MULTI_TOKEN2, 3, ... ; all must be admins of LOG_CHANNEL)
# MULTI_TOKEN2=
# MULTI_TOKEN3=

# ---- Optional: access / admin ----
ADMINS=123456789              # space/comma separated Telegram user IDs (admin commands + payment approval)
FORCE_SUB_CHANNEL=            # username/id users must join (bot must be admin); empty disables force-sub
FORCE_SUB_INVITE=             # custom join link (defaults to t.me/<username>)

# ---- Subscription / payments ----
UPI_ID=                       # e.g. alaska@upi ; empty disables purchases (manual UPI fallback)
ADMIN_GROUP_ID=0              # group where payment requests are posted; 0 = DM the ADMINS
# Razorpay Standard Checkout (preferred when set; auto-activates plan on success)
RAZORPAY_KEY_ID=              # e.g. rzp_test_xxxxxxxx (safe to expose to frontend)
RAZORPAY_KEY_SECRET=          # server-side only — NEVER expose to frontend
RAZORPAY_WEBHOOK_SECRET=      # optional, for webhook verification
PLUS_PRICE=27                 # rupees / 30 days
PRO_PRICE=67
FREE_DAILY=2                  # links per day
PLUS_DAILY=20
PRO_DAILY=100
FREE_MAX_GB=2                 # max file size (GB)
PLUS_MAX_GB=4
PRO_MAX_GB=10
FREE_EXPIRY_H=6               # stream-link validity (hours)
PLUS_EXPIRY_H=24
PRO_EXPIRY_H=168

# ---- Optional: server ----
PORT=8080
BIND_HOST=0.0.0.0
WORKERS=4
